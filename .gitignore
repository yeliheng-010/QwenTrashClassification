# ============================================
# 垃圾分类系统 - Git 忽略配置
# ============================================

# ---- 环境变量文件（包含数据库密码、API Key 等敏感信息） ----
.env

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---- Python 虚拟环境 ----
.venv/
venv/
env/

# ---- Node.js / 前端 ----
node_modules/

# ---- 日志文件 ----
*.log

# ---- 数据库文件 ----
*.db
*.sqlite3

# ---- IDE / 编辑器配置 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 操作系统生成文件 ----
.DS_Store
Thumbs.db
