# ============================================
# 垃圾分类系统 - 环境变量配置示例文件
# ============================================
# 使用方法：
# 1. 复制此文件并重命名为 .env
# 2. 填写你自己的数据库密码、API Key 等敏感信息
# 3. .env 文件已被 .gitignore 忽略，不会被提交到 Git

# ---- 数据库配置 ----
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://your_db_user:your_db_password@127.0.0.1:3306/your_db_name

# ---- 硅基流动 API 配置 (OpenAI 兼容接口，用于调用通义千问大模型) ----
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ---- 应用安全配置 ----
# JWT 密钥，用于签发和验证用户登录令牌（请使用一个足够复杂的随机字符串）
SECRET_KEY=your_secret_key_here
# JWT 加密算法
ALGORITHM=HS256
# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30
